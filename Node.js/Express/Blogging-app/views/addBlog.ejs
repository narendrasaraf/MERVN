<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('./partials/head.ejs') %>
  <title>Write Blog | Bloggify</title>
</head>
<body class="bg-light">
  <%- include('./partials/nav.ejs') %>

  <div class="container py-5" style="max-width: 760px;">
    <div class="card shadow-sm border-0 rounded-4">
      <div class="card-body p-4 p-md-5">
        <h1 class="h3 fw-bold mb-2">Write a blog</h1>
        <p class="text-muted mb-4">Share a title and some content with the community.</p>

        <form method="POST" action="/blog" class="d-grid gap-3">
          <div>
            <label class="form-label" for="title">Title</label>
            <input class="form-control" type="text" id="title" name="title" required>
          </div>
          <div>
            <label class="form-label" for="body">Body</label>
            <textarea class="form-control" id="body" name="body" rows="10" required></textarea>
          </div>
          <div>
            <label class="form-label" for="coverImageURL">Cover image URL</label>
            <input class="form-control" type="text" id="coverImageURL" name="coverImageURL" placeholder="Optional image URL">
          </div>
          <button class="btn btn-primary btn-lg" type="submit">Publish Blog</button>
        </form>
      </div>
    </div>
  </div>

  <%- include('./partials/scripts.ejs') %>
</body>
</html>