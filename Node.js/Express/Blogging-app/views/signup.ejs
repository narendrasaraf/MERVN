<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('./partials/head.ejs') %>
  <title>Sign Up | Bloggify</title>
</head>
<body class="bg-light">
  <%- include('./partials/nav.ejs') %>

  <div class="container py-5" style="max-width: 560px;">
    <div class="card shadow-sm border-0 rounded-4">
      <div class="card-body p-4 p-md-5">
        <h1 class="h3 fw-bold mb-2">Create account</h1>
        <p class="text-muted mb-4">Join Bloggify and start publishing.</p>

        <form method="POST" action="/user/signup" class="d-grid gap-3">
          <div>
            <label class="form-label" for="fullName">Full name</label>
            <input class="form-control" type="text" id="fullName" name="fullName" required>
          </div>
          <div>
            <label class="form-label" for="email">Email</label>
            <input class="form-control" type="email" id="email" name="email" required>
          </div>
          <div>
            <label class="form-label" for="password">Password</label>
            <input class="form-control" type="password" id="password" name="password" required>
          </div>
          <button class="btn btn-primary btn-lg" type="submit">Create Account</button>
        </form>

        <p class="text-muted mt-4 mb-0">
          Already have an account? <a href="/user/signin">Sign in</a>
        </p>
      </div>
    </div>
  </div>

  <%- include('./partials/scripts.ejs') %>
</body>
</html>