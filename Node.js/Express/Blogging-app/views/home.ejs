<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head.ejs') %>
    <title>Homepage | Bloggify</title>
</head>
<body class="bg-light">

    <%- include('./partials/nav.ejs') %>

    <div class="container my-5">
        <h2 class="mb-4 text-center text-md-start font-monospace text-uppercase fw-bold text-dark">All Blogs</h2>
        
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            <% if (locals.blogs && blogs.length > 0) { %>
                <% blogs.forEach(blog => { %>
                    <div class="col">
                        <div class="card h-100 shadow-sm border-0 rounded-3 overflow-hidden">
                            <img src="<%= blog.coverImageURL %>" class="card-img-top object-fit-cover" style="height: 220px;" alt="<%= blog.title %>">
                            
                            <div class="card-body d-flex flex-column justify-content-between p-4">
                                <div>
                                    <h5 class="card-title fw-semibold text-truncate mb-2" title="<%= blog.title %>">
                                        <%= blog.title %>
                                    </h5>
                                    <p class="card-text text-secondary text-break line-clamp mb-4" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                                        <%= blog.body %>
                                    </p>
                                </div>
                                
                                <a href="/blog/<%= blog._id %>" class="btn btn-primary w-100 py-2 rounded-2 mt-auto">View Details</a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-12 text-center my-5 py-5">
                    <p class="text-muted fs-5">No blogs found. Be the first to share your thoughts!</p>
                    <% if (locals.user) { %>
                        <a href="/blog/add-new" class="btn btn-outline-primary btn-sm px-4 mt-2">Write a Blog</a>
                    <% } %>
                </div>
            <% } %>
        </div>
    </div>

    <%- include('./partials/scripts.ejs') %>
    
</body>
</html>